<!DOCTYPE html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quiz Pro | Testy i progres</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
      :root {
        --bg: #0b1020;
        --bg-soft: #121936;
        --panel: rgba(15, 23, 42, 0.86);
        --panel-strong: rgba(15, 23, 42, 0.95);
        --line: rgba(148, 163, 184, 0.18);
        --text: #e5eefc;
        --muted: #94a3b8;
        --primary: #4f46e5;
        --primary-2: #7c3aed;
        --success: #22c55e;
        --danger: #ef4444;
        --warning: #f59e0b;
        --shadow: 0 18px 60px rgba(2, 6, 23, 0.42);
        --radius-xl: 28px;
        --radius-lg: 22px;
        --radius-md: 16px;
      }

      * {
        box-sizing: border-box;
      }

      html, body {
        margin: 0;
        min-height: 100%;
        font-family: 'Inter', sans-serif;
        background:
          radial-gradient(circle at top left, rgba(79, 70, 229, 0.35), transparent 26%),
          radial-gradient(circle at top right, rgba(124, 58, 237, 0.22), transparent 24%),
          linear-gradient(180deg, #060913 0%, #0b1020 45%, #0f172a 100%);
        color: var(--text);
      }

      body {
        padding: 28px;
      }

      .app-shell {
        width: min(1200px, 100%);
        margin: 0 auto;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 28px;
        padding: 18px 22px;
        background: rgba(11, 16, 32, 0.55);
        border: 1px solid var(--line);
        border-radius: 22px;
        backdrop-filter: blur(18px);
        box-shadow: var(--shadow);
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 14px;
      }

      .brand-badge {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        display: grid;
        place-items: center;
        font-weight: 800;
        background: linear-gradient(135deg, var(--primary), var(--primary-2));
        color: white;
        box-shadow: 0 10px 30px rgba(79, 70, 229, 0.35);
      }

      .brand h1 {
        margin: 0;
        font-size: 1.15rem;
      }

      .brand p {
        margin: 3px 0 0;
        color: var(--muted);
        font-size: 0.94rem;
      }

      .nav {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .nav button,
      .primary-btn,
      .ghost-btn,
      .answer-btn,
      .small-btn {
        border: none;
        font: inherit;
        cursor: pointer;
        transition: 0.22s ease;
      }

      .nav button {
        padding: 12px 18px;
        border-radius: 14px;
        color: var(--text);
        background: rgba(148, 163, 184, 0.08);
        border: 1px solid transparent;
      }

      .nav button.active,
      .nav button:hover {
        background: rgba(79, 70, 229, 0.18);
        border-color: rgba(99, 102, 241, 0.45);
      }

      .hero,
      .panel {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow);
        backdrop-filter: blur(22px);
      }

      .hero {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 24px;
        padding: 34px;
      }

      .hero h2 {
        margin: 0 0 14px;
        font-size: clamp(2rem, 5vw, 3.3rem);
        line-height: 1.06;
      }

      .hero p {
        margin: 0 0 24px;
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.7;
        max-width: 62ch;
      }

      .stats-grid,
      .cards-grid {
        display: grid;
        gap: 18px;
      }

      .stats-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        margin-top: 24px;
      }

      .cards-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        margin-top: 22px;
      }

      .stat-card,
      .feature-card,
      .side-card,
      .dog-card,
      .name-panel {
        border-radius: var(--radius-lg);
        border: 1px solid var(--line);
        background: rgba(15, 23, 42, 0.72);
      }

      .stat-card {
        padding: 18px;
      }

      .stat-card .label,
      .feature-card .label,
      .result-card .label,
      .field-label {
        color: var(--muted);
        font-size: 0.9rem;
      }

      .stat-card .value {
        margin-top: 8px;
        font-size: 1.65rem;
        font-weight: 800;
      }

      .feature-card,
      .dog-card,
      .name-panel {
        padding: 18px;
      }

      .feature-card h3,
      .side-card h3,
      .panel h3,
      .dog-card h3,
      .name-panel h3 {
        margin: 0 0 10px;
        font-size: 1rem;
      }

      .feature-card p,
      .side-card p,
      .dog-card p,
      .name-panel p {
        margin: 0;
        color: var(--muted);
        line-height: 1.6;
      }

      .hero-side {
        display: flex;
        flex-direction: column;
        gap: 18px;
      }

      .side-card {
        padding: 22px;
      }

      .dog-card {
        overflow: hidden;
        padding: 0;
      }

      .dog-photo {
        display: block;
        width: 100%;
        height: 260px;
        object-fit: cover;
        opacity: 0.92;
      }

      .dog-card-content {
        padding: 18px;
      }

      .primary-btn,
      .ghost-btn,
      .small-btn {
        padding: 13px 18px;
        border-radius: 14px;
        font-weight: 700;
      }

      .primary-btn {
        background: linear-gradient(135deg, var(--primary), var(--primary-2));
        color: white;
        box-shadow: 0 10px 28px rgba(79, 70, 229, 0.38);
      }

      .primary-btn:hover,
      .small-btn:hover {
        transform: translateY(-1px);
        filter: brightness(1.05);
      }

      .ghost-btn {
        background: rgba(148, 163, 184, 0.08);
        color: var(--text);
        border: 1px solid var(--line);
      }

      .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .panel {
        padding: 28px;
      }

      .panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        margin-bottom: 22px;
      }

      .panel-header p {
        margin: 6px 0 0;
        color: var(--muted);
      }

      .name-panel {
        margin-top: 18px;
      }

      .form-grid {
        display: grid;
        grid-template-columns: 1.3fr auto;
        gap: 12px;
        margin-top: 16px;
      }

      .name-input {
        width: 100%;
        padding: 15px 16px;
        border-radius: 16px;
        border: 1px solid rgba(148, 163, 184, 0.18);
        background: rgba(11, 16, 32, 0.82);
        color: var(--text);
        font: inherit;
        outline: none;
      }

      .name-input:focus {
        border-color: rgba(99, 102, 241, 0.7);
        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.16);
      }

      .status-note {
        margin-top: 12px;
        color: var(--muted);
        font-size: 0.92rem;
      }

      .quiz-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
        margin-bottom: 22px;
      }

      .quiz-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .meta-pill {
        padding: 10px 14px;
        border-radius: 999px;
        background: rgba(148, 163, 184, 0.08);
        border: 1px solid var(--line);
        color: var(--text);
        font-size: 0.95rem;
      }

      .progress-track {
        height: 12px;
        border-radius: 999px;
        background: rgba(148, 163, 184, 0.12);
        overflow: hidden;
        margin-bottom: 24px;
      }

      .progress-bar {
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, var(--primary), var(--primary-2));
        width: 0;
        transition: width 0.25s ease;
      }

      .question-box {
        padding: 24px;
        border-radius: 24px;
        background: rgba(15, 23, 42, 0.68);
        border: 1px solid var(--line);
      }

      .question-label {
        color: #a5b4fc;
        font-weight: 700;
        margin-bottom: 10px;
      }

      .question-text {
        font-size: clamp(1.15rem, 2.4vw, 1.55rem);
        line-height: 1.5;
        margin-bottom: 24px;
        font-weight: 700;
      }

      .answers {
        display: grid;
        gap: 12px;
      }

      .answer-btn {
        width: 100%;
        text-align: left;
        padding: 16px 18px;
        border-radius: 18px;
        color: var(--text);
        background: rgba(148, 163, 184, 0.08);
        border: 1px solid rgba(148, 163, 184, 0.16);
      }

      .answer-btn:hover {
        transform: translateY(-1px);
        border-color: rgba(99, 102, 241, 0.42);
      }

      .answer-btn.selected {
        background: rgba(79, 70, 229, 0.18);
        border-color: rgba(99, 102, 241, 0.7);
        box-shadow: inset 0 0 0 1px rgba(99, 102, 241, 0.35);
      }

      .quiz-actions,
      .result-actions,
      .table-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 12px;
        margin-top: 22px;
      }

      .small-btn {
        background: rgba(148, 163, 184, 0.08);
        color: var(--text);
        border: 1px solid var(--line);
      }

      .table-wrap {
        overflow-x: auto;
        border: 1px solid var(--line);
        border-radius: 18px;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        min-width: 760px;
        background: rgba(15, 23, 42, 0.56);
      }

      th, td {
        padding: 16px;
        text-align: left;
        border-bottom: 1px solid rgba(148, 163, 184, 0.12);
      }

      th {
        color: #cbd5e1;
        font-size: 0.92rem;
        background: rgba(15, 23, 42, 0.9);
      }

      td {
        color: var(--text);
      }

      .score-badge {
        display: inline-flex;
        align-items: center;
        padding: 8px 12px;
        border-radius: 999px;
        font-weight: 700;
        font-size: 0.9rem;
      }

      .score-high { background: rgba(34, 197, 94, 0.16); color: #86efac; }
      .score-mid { background: rgba(245, 158, 11, 0.16); color: #fcd34d; }
      .score-low { background: rgba(239, 68, 68, 0.16); color: #fca5a5; }

      .empty-state {
        padding: 34px;
        border-radius: 22px;
        text-align: center;
        color: var(--muted);
        border: 1px dashed rgba(148, 163, 184, 0.24);
        background: rgba(15, 23, 42, 0.42);
      }

      .result-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 18px;
        margin-top: 24px;
      }

      .result-card {
        padding: 22px;
        border-radius: 22px;
        border: 1px solid var(--line);
        background: rgba(15, 23, 42, 0.72);
      }

      .result-card .big {
        margin-top: 8px;
        font-size: 1.5rem;
        font-weight: 800;
      }

      .chart-shell {
        padding: 22px;
        border-radius: 22px;
        border: 1px solid var(--line);
        background: rgba(15, 23, 42, 0.72);
      }

      .footer-note {
        margin-top: 24px;
        color: var(--muted);
        font-size: 0.92rem;
      }

      .hidden {
        display: none !important;
      }

      @media (max-width: 980px) {
        .hero,
        .cards-grid,
        .stats-grid,
        .result-grid,
        .form-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 720px) {
        body {
          padding: 16px;
        }

        .topbar,
        .hero,
        .panel {
          padding: 18px;
        }

        .panel-header,
        .quiz-head,
        .table-actions {
          align-items: flex-start;
          flex-direction: column;
        }

        .dog-photo {
          height: 220px;
        }
      }
    </style>
  </head>
  <body>
    <div class="app-shell">
      <header class="topbar">
        <div class="brand">
          <div class="brand-badge">QP</div>
          <div>
            <h1>Quiz Pro SG</h1>
            <p>Profesjonalna platforma testowa z rankingiem i analizą postępów</p>
          </div>
        </div>
        <nav class="nav">
          <button class="active" data-view="home">Start</button>
          <button data-view="test">Test</button>
          <button data-view="ranking">Ranking</button>
          <button data-view="progress">Progres</button>
        </nav>
      </header>

      <main>
        <section id="view-home" class="view">
          <div class="hero">
            <div>
              <h2>Sprawdź wiedzę w nowoczesnym teście online.</h2>
              <p>
                Aplikacja losuje 10 pytań z bazy JSON, mierzy czas rozwiązania,
                zapisuje wyniki w pamięci przeglądarki i prezentuje historię podejść
                w przejrzystym rankingu oraz na wykresie progresu.
              </p>
              <div class="cta-row">
                <button class="primary-btn" id="startTestHero">Przejdź do testu</button>
                <button class="ghost-btn" id="goProgress">Zobacz progres</button>
              </div>

              <div class="stats-grid">
                <div class="stat-card">
                  <div class="label">Liczba pytań w bazie</div>
                  <div class="value" id="statQuestionCount">0</div>
                </div>
                <div class="stat-card">
                  <div class="label">Liczba zapisanych podejść</div>
                  <div class="value" id="statAttemptsCount">0</div>
                </div>
                <div class="stat-card">
                  <div class="label">Najlepszy wynik</div>
                  <div class="value" id="statBestScore">0%</div>
                </div>
              </div>
            </div>

            <div class="hero-side">
              <div class="dog-card">
                <img
                  class="dog-photo"
                  src="https://commons.wikimedia.org/wiki/Special:FilePath/Chien_Cavalier_King_Charles_2.jpg"
                  alt="Czarnobiały cavalier king charles spaniel"
                />
                <div class="dog-card-content">
                  <h3>Przyjazny akcent wizualny</h3>
                  <p>
                    Delikatnie wkomponowany cavalier dodaje stronie bardziej ciepłego,
                    eleganckiego charakteru bez odciągania uwagi od testu.
                  </p>
                </div>
              </div>
              <div class="side-card">
                <h3>Jak to działa?</h3>
                <p>
                  Użytkownik wpisuje imię lub nazwę, rozpoczyna test i odpowiada kolejno
                  na 10 losowych pytań z pliku JSON.
                </p>
              </div>
              <div class="side-card">
                <h3>Zapis wyników</h3>
                <p>
                  Każde podejście jest zapisywane w localStorage razem z nazwą osoby,
                  dzięki czemu ranking i wykres progresu pozostają dostępne po odświeżeniu strony.
                </p>
              </div>
            </div>
          </div>

          <div class="cards-grid">
            <div class="feature-card">
              <div class="label">Moduł testowy</div>
              <h3>10 losowych pytań</h3>
              <p>Za każdym razem inny zestaw pytań pobrany z pliku <strong>questions_sg_203.json</strong>.</p>
            </div>
            <div class="feature-card">
              <div class="label">Wyniki</div>
              <h3>Ocena, czas i uczestnik</h3>
              <p>Po zakończeniu użytkownik widzi procent poprawnych odpowiedzi, czas oraz swoją nazwę.</p>
            </div>
            <div class="feature-card">
              <div class="label">Analityka</div>
              <h3>Ranking i progres</h3>
              <p>Historia podejść, najlepsze wyniki oraz wykres kolejnych testów zapisanych w przeglądarce.</p>
            </div>
          </div>
        </section>

        <section id="view-test" class="view hidden">
          <div class="panel">
            <div id="quizIntro">
              <div class="panel-header">
                <div>
                  <h3>Tryb testu</h3>
                  <p>Wpisz nazwę osoby rozwiązującej test i rozpocznij 10 pytań z bazy JSON.</p>
                </div>
              </div>

              <div class="name-panel">
                <div class="field-label">Imię i nazwisko lub nazwa użytkownika</div>
                <div class="form-grid">
                  <input
                    id="participantNameInput"
                    class="name-input"
                    type="text"
                    placeholder="Np. Jan Kowalski"
                    maxlength="60"
                  />
                  <button class="primary-btn" id="startTestBtn">Start testu</button>
                </div>
                <div class="status-note" id="questionsStatus">
                  Trwa przygotowywanie bazy pytań...
                </div>
              </div>

              <div class="footer-note">
                Umieść plik <strong>questions_sg_203.json</strong> w tym samym folderze co <strong>index.html</strong>,
                aby aplikacja automatycznie wczytała pytania po uruchomieniu strony.
              </div>
            </div>

            <div id="quizGame" class="hidden">
              <div class="quiz-head">
                <div>
                  <h3>Test wiedzy</h3>
                  <p id="quizSubtitle">Odpowiedz na wszystkie pytania.</p>
                </div>
                <div class="quiz-meta">
                  <div class="meta-pill" id="participantDisplay">Uczestnik: —</div>
                  <div class="meta-pill" id="questionCounter">Pytanie 1 / 10</div>
                  <div class="meta-pill" id="timerDisplay">00:00</div>
                </div>
              </div>

              <div class="progress-track">
                <div class="progress-bar" id="progressBar"></div>
              </div>

              <div class="question-box">
                <div class="question-label" id="questionCategory">Kategoria</div>
                <div class="question-text" id="questionText"></div>
                <div class="answers" id="answersContainer"></div>
              </div>

              <div class="quiz-actions">
                <button class="small-btn" id="cancelTestBtn">Anuluj</button>
                <button class="primary-btn" id="nextQuestionBtn" disabled>Dalej</button>
              </div>
            </div>

            <div id="quizResult" class="hidden">
              <div class="panel-header">
                <div>
                  <h3>Wynik testu</h3>
                  <p>Podsumowanie ostatniego podejścia zapisane w historii wyników.</p>
                </div>
              </div>

              <div class="result-grid">
                <div class="result-card">
                  <div class="label">Uczestnik</div>
                  <div class="big" id="resultParticipant">—</div>
                </div>
                <div class="result-card">
                  <div class="label">Wynik procentowy</div>
                  <div class="big" id="resultScore">0%</div>
                </div>
                <div class="result-card">
                  <div class="label">Poprawne odpowiedzi</div>
                  <div class="big" id="resultCorrect">0 / 10</div>
                </div>
                <div class="result-card">
                  <div class="label">Czas testu</div>
                  <div class="big" id="resultTime">00:00</div>
                </div>
              </div>

              <div class="result-actions">
                <button class="ghost-btn" id="goRankingBtn">Przejdź do rankingu</button>
                <button class="primary-btn" id="restartTestBtn">Rozwiąż ponownie</button>
              </div>
            </div>
          </div>
        </section>

        <section id="view-ranking" class="view hidden">
          <div class="panel">
            <div class="panel-header">
              <div>
                <h3>Ranking wyników</h3>
                <p>Lista wszystkich zapisanych podejść, sortowana od najlepszego wyniku.</p>
              </div>
              <div class="table-actions">
                <button class="small-btn" id="clearResultsBtn">Wyczyść wyniki</button>
              </div>
            </div>
            <div id="rankingContent"></div>
          </div>
        </section>

        <section id="view-progress" class="view hidden">
          <div class="panel">
            <div class="panel-header">
              <div>
                <h3>Progres użytkownika</h3>
                <p>Wykres prezentuje procentowy wynik kolejnych podejść do testu.</p>
              </div>
            </div>
            <div id="progressContent"></div>
          </div>
        </section>
      </main>
    </div>

    <script>
      let questionBank = [];

      const STORAGE_KEY = 'quizProResults';
      const QUESTIONS_PER_TEST = 10;

      const state = {
        currentView: 'home',
        testQuestions: [],
        currentQuestionIndex: 0,
        selectedAnswerIndex: null,
        answersMap: [],
        timerInterval: null,
        testStartTime: null,
        elapsedSeconds: 0,
        chartInstance: null,
        currentParticipant: '',
        questionsLoaded: false
      };

      const navButtons = document.querySelectorAll('.nav button');
      const views = document.querySelectorAll('.view');
      const rankingContent = document.getElementById('rankingContent');
      const progressContent = document.getElementById('progressContent');

      const quizIntro = document.getElementById('quizIntro');
      const quizGame = document.getElementById('quizGame');
      const quizResult = document.getElementById('quizResult');

      const participantNameInput = document.getElementById('participantNameInput');
      const participantDisplay = document.getElementById('participantDisplay');
      const questionsStatus = document.getElementById('questionsStatus');
      const startTestBtn = document.getElementById('startTestBtn');

      const questionCounter = document.getElementById('questionCounter');
      const timerDisplay = document.getElementById('timerDisplay');
      const progressBar = document.getElementById('progressBar');
      const questionCategory = document.getElementById('questionCategory');
      const questionText = document.getElementById('questionText');
      const answersContainer = document.getElementById('answersContainer');
      const nextQuestionBtn = document.getElementById('nextQuestionBtn');

      function formatTime(seconds) {
        const mins = String(Math.floor(seconds / 60)).padStart(2, '0');
        const secs = String(seconds % 60).padStart(2, '0');
        return `${mins}:${secs}`;
      }

      function loadResults() {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          return raw ? JSON.parse(raw) : [];
        } catch (error) {
          console.error('Błąd odczytu wyników:', error);
          return [];
        }
      }

      function saveResults(results) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(results));
      }

      function getScoreClass(score) {
        if (score >= 80) return 'score-badge score-high';
        if (score >= 50) return 'score-badge score-mid';
        return 'score-badge score-low';
      }

      function shuffleArray(array) {
        const copy = [...array];
        for (let i = copy.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [copy[i], copy[j]] = [copy[j], copy[i]];
        }
        return copy;
      }

      function updateTopStats() {
        const results = loadResults();
        const best = results.length ? Math.max(...results.map(r => r.scorePercent)) : 0;
        document.getElementById('statQuestionCount').textContent = questionBank.length;
        document.getElementById('statAttemptsCount').textContent = results.length;
        document.getElementById('statBestScore').textContent = `${best}%`;
      }

      function switchView(view) {
        state.currentView = view;
        views.forEach(section => {
          section.classList.toggle('hidden', section.id !== `view-${view}`);
        });
        navButtons.forEach(button => {
          button.classList.toggle('active', button.dataset.view === view);
        });

        if (view === 'ranking') renderRanking();
        if (view === 'progress') renderProgress();
      }

      function startTimer() {
        clearInterval(state.timerInterval);
        state.testStartTime = Date.now();
        state.elapsedSeconds = 0;
        timerDisplay.textContent = formatTime(0);

        state.timerInterval = setInterval(() => {
          state.elapsedSeconds = Math.floor((Date.now() - state.testStartTime) / 1000);
          timerDisplay.textContent = formatTime(state.elapsedSeconds);
        }, 1000);
      }

      function stopTimer() {
        clearInterval(state.timerInterval);
      }

      async function loadQuestions() {
        startTestBtn.disabled = true;
        questionsStatus.textContent = 'Wczytywanie bazy pytań...';

        try {
          const response = await fetch('./questions_sg_203.json');
          if (!response.ok) {
            throw new Error(`HTTP ${response.status}`);
          }

          const data = await response.json();
          if (!Array.isArray(data)) {
            throw new Error('Plik JSON ma nieprawidłowy format.');
          }

          questionBank = data;
          state.questionsLoaded = true;
          questionsStatus.textContent = `Baza pytań gotowa. Wczytano ${questionBank.length} pytań.`;
          startTestBtn.disabled = false;
          updateTopStats();
        } catch (error) {
          console.error('Błąd ładowania pytań:', error);
          state.questionsLoaded = false;
          questionBank = [];
          questionsStatus.textContent = 'Nie udało się wczytać questions_sg_203.json. Sprawdź, czy plik jest w tym samym folderze co index.html.';
          updateTopStats();
        }
      }

      function startTest() {
        const participantName = participantNameInput.value.trim();

        if (!state.questionsLoaded) {
          alert('Baza pytań nie została jeszcze poprawnie wczytana.');
          return;
        }

        if (!participantName) {
          alert('Wpisz imię i nazwisko albo nazwę użytkownika przed rozpoczęciem testu.');
          participantNameInput.focus();
          return;
        }

        if (questionBank.length < QUESTIONS_PER_TEST) {
          alert(`Baza pytań musi zawierać co najmniej ${QUESTIONS_PER_TEST} pytań.`);
          return;
        }

        state.currentParticipant = participantName;
        participantDisplay.textContent = `Uczestnik: ${state.currentParticipant}`;
        state.testQuestions = shuffleArray(questionBank).slice(0, QUESTIONS_PER_TEST);
        state.currentQuestionIndex = 0;
        state.selectedAnswerIndex = null;
        state.answersMap = Array(QUESTIONS_PER_TEST).fill(null);

        quizIntro.classList.add('hidden');
        quizResult.classList.add('hidden');
        quizGame.classList.remove('hidden');

        startTimer();
        renderQuestion();
        switchView('test');
      }

      function renderQuestion() {
        const question = state.testQuestions[state.currentQuestionIndex];
        state.selectedAnswerIndex = state.answersMap[state.currentQuestionIndex];

        questionCounter.textContent = `Pytanie ${state.currentQuestionIndex + 1} / ${QUESTIONS_PER_TEST}`;
        questionCategory.textContent = question.category || 'Pytanie testowe';
        questionText.textContent = question.question;
        progressBar.style.width = `${((state.currentQuestionIndex + 1) / QUESTIONS_PER_TEST) * 100}%`;

        answersContainer.innerHTML = '';
        question.answers.forEach((answer, index) => {
          const button = document.createElement('button');
          button.className = 'answer-btn';
          if (state.selectedAnswerIndex === index) button.classList.add('selected');
          button.textContent = `${String.fromCharCode(65 + index)}. ${answer}`;
          button.addEventListener('click', () => selectAnswer(index));
          answersContainer.appendChild(button);
        });

        nextQuestionBtn.disabled = state.selectedAnswerIndex === null;
        nextQuestionBtn.textContent = state.currentQuestionIndex === QUESTIONS_PER_TEST - 1 ? 'Zakończ test' : 'Dalej';
      }

      function selectAnswer(index) {
        state.selectedAnswerIndex = index;
        state.answersMap[state.currentQuestionIndex] = index;
        [...answersContainer.children].forEach((button, btnIndex) => {
          button.classList.toggle('selected', btnIndex === index);
        });
        nextQuestionBtn.disabled = false;
      }

      function nextQuestion() {
        if (state.selectedAnswerIndex === null) return;

        if (state.currentQuestionIndex < QUESTIONS_PER_TEST - 1) {
          state.currentQuestionIndex += 1;
          renderQuestion();
          return;
        }

        finishTest();
      }

      function finishTest() {
        stopTimer();
        const correctAnswers = state.testQuestions.reduce((acc, question, index) => {
          return acc + (state.answersMap[index] === question.correctIndex ? 1 : 0);
        }, 0);

        const scorePercent = Math.round((correctAnswers / QUESTIONS_PER_TEST) * 100);
        const totalTime = state.elapsedSeconds;
        const attemptDate = new Date();

        const results = loadResults();
        results.push({
          id: crypto.randomUUID ? crypto.randomUUID() : `${Date.now()}-${Math.random()}`,
          participantName: state.currentParticipant,
          scorePercent,
          correctAnswers,
          totalQuestions: QUESTIONS_PER_TEST,
          totalTime,
          dateISO: attemptDate.toISOString(),
          displayDate: attemptDate.toLocaleString('pl-PL')
        });
        saveResults(results);

        document.getElementById('resultParticipant').textContent = state.currentParticipant;
        document.getElementById('resultScore').textContent = `${scorePercent}%`;
        document.getElementById('resultCorrect').textContent = `${correctAnswers} / ${QUESTIONS_PER_TEST}`;
        document.getElementById('resultTime').textContent = formatTime(totalTime);

        quizGame.classList.add('hidden');
        quizResult.classList.remove('hidden');
        updateTopStats();
      }

      function cancelTest() {
        stopTimer();
        state.testQuestions = [];
        state.answersMap = [];
        state.currentQuestionIndex = 0;
        quizGame.classList.add('hidden');
        quizResult.classList.add('hidden');
        quizIntro.classList.remove('hidden');
      }

      function renderRanking() {
        const results = loadResults();
        if (!results.length) {
          rankingContent.innerHTML = `
            <div class="empty-state">
              Brak zapisanych wyników. Rozwiąż pierwszy test, aby zapełnić ranking.
            </div>
          `;
          return;
        }

        const sorted = [...results].sort((a, b) => {
          if (b.scorePercent !== a.scorePercent) return b.scorePercent - a.scorePercent;
          return a.totalTime - b.totalTime;
        });

        rankingContent.innerHTML = `
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>#</th>
                  <th>Uczestnik</th>
                  <th>Data</th>
                  <th>Wynik</th>
                  <th>Poprawne</th>
                  <th>Czas</th>
                </tr>
              </thead>
              <tbody>
                ${sorted.map((item, index) => `
                  <tr>
                    <td>${index + 1}</td>
                    <td>${item.participantName || '—'}</td>
                    <td>${item.displayDate}</td>
                    <td><span class="${getScoreClass(item.scorePercent)}">${item.scorePercent}%</span></td>
                    <td>${item.correctAnswers} / ${item.totalQuestions}</td>
                    <td>${formatTime(item.totalTime)}</td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        `;
      }

      function renderProgress() {
        const results = loadResults().sort((a, b) => new Date(a.dateISO) - new Date(b.dateISO));

        if (!results.length) {
          progressContent.innerHTML = `
            <div class="empty-state">
              Brak danych do wyświetlenia. Ukończ przynajmniej jeden test, aby zobaczyć wykres progresu.
            </div>
          `;
          return;
        }

        progressContent.innerHTML = `
          <div class="chart-shell">
            <canvas id="progressChart" height="110"></canvas>
          </div>
          <div class="footer-note">
            Oś X przedstawia kolejne podejścia, a oś Y wynik procentowy uzyskany w teście.
          </div>
        `;

        const ctx = document.getElementById('progressChart');
        if (state.chartInstance) {
          state.chartInstance.destroy();
        }

        state.chartInstance = new Chart(ctx, {
          type: 'line',
          data: {
            labels: results.map((item, index) => `${index + 1}. ${item.participantName || 'Uczestnik'}`),
            datasets: [{
              label: 'Wynik %',
              data: results.map(item => item.scorePercent),
              tension: 0.35,
              fill: true,
              borderWidth: 3,
              pointRadius: 4,
              pointHoverRadius: 6
            }]
          },
          options: {
            responsive: true,
            plugins: {
              legend: {
                labels: {
                  color: '#e5eefc'
                }
              },
              tooltip: {
                callbacks: {
                  afterLabel: (context) => {
                    const item = results[context.dataIndex];
                    return [
                      `Uczestnik: ${item.participantName || '—'}`,
                      `Czas: ${formatTime(item.totalTime)}`,
                      `Data: ${item.displayDate}`
                    ];
                  }
                }
              }
            },
            scales: {
              x: {
                ticks: { color: '#cbd5e1' },
                grid: { color: 'rgba(148, 163, 184, 0.08)' }
              },
              y: {
                min: 0,
                max: 100,
                ticks: {
                  color: '#cbd5e1',
                  callback: value => `${value}%`
                },
                grid: { color: 'rgba(148, 163, 184, 0.08)' }
              }
            }
          }
        });
      }

      function clearResults() {
        const confirmed = confirm('Czy na pewno chcesz usunąć wszystkie zapisane wyniki?');
        if (!confirmed) return;
        localStorage.removeItem(STORAGE_KEY);
        updateTopStats();
        renderRanking();
        renderProgress();
      }

      navButtons.forEach(button => {
        button.addEventListener('click', () => switchView(button.dataset.view));
      });

      document.getElementById('startTestHero').addEventListener('click', () => {
        switchView('test');
        participantNameInput.focus();
      });
      document.getElementById('goProgress').addEventListener('click', () => switchView('progress'));
      document.getElementById('nextQuestionBtn').addEventListener('click', nextQuestion);
      document.getElementById('cancelTestBtn').addEventListener('click', cancelTest);
      document.getElementById('restartTestBtn').addEventListener('click', () => {
        quizResult.classList.add('hidden');
        quizIntro.classList.remove('hidden');
        participantNameInput.focus();
      });
      document.getElementById('goRankingBtn').addEventListener('click', () => switchView('ranking'));
      document.getElementById('clearResultsBtn').addEventListener('click', clearResults);
      startTestBtn.addEventListener('click', startTest);
      participantNameInput.addEventListener('keydown', (event) => {
        if (event.key === 'Enter') startTest();
      });

      updateTopStats();
      switchView('home');
      loadQuestions();
    </script>
  </body>
</html>
